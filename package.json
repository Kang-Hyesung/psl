{
  "name": "chrome-extension-kyobo-hide-list",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "lint": "tsc --noEmit --pretty false",
